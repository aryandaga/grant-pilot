# ─── Database ────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/grantpilot

# ─── Auth ────────────────────────────────────────────────────────────────────
# Random secret used to sign JWT tokens — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-deploying

# Token lifetime in hours (default: 24)
ACCESS_TOKEN_EXPIRE_HOURS=24

# ─── AI ──────────────────────────────────────────────────────────────────────
# Gemini API key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
